# ──────────────────────────────────────────────────────
#  NBA GBSV v6 — Environment Variable Reference
# ──────────────────────────────────────────────────────
#  Copy this file to .env and fill in your API keys.
#  The default workflow is the VS Code dev container.
#  The dev container injects DATABASE_URL for the bundled Postgres
#  service, so this file is mainly for secrets and local overrides.
#  Production secrets come from Azure and are not read from repo-local
#  env files.
# ──────────────────────────────────────────────────────

# ── Required secrets (must be set in .env) ────────────
# The dev container injects placeholder values so a fresh clone can
# boot locally. Replace these with real keys for live API calls.
ODDS_API_KEY=
BASKETBALL_API_KEY=

# ── Database ──────────────────────────────────────────
# Dev container overrides this to:
#   postgresql+asyncpg://postgres:postgres@db:5432/nba_gbsv
# Host-only runs can keep localhost.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nba_gbsv

# ── App ───────────────────────────────────────────────
# Valid values: development | test | production
APP_ENV=development
LOG_LEVEL=INFO

# ── Azure (production only) ──────────────────────────
AZURE_KEY_VAULT_URL=

# ── Teams delivery ────────────────────────────────────
# Preferred: Graph API posting (uses DefaultAzureCredential)
# TEAMS_TEAM_ID=6d55cb22-b8b0-43a4-8ec1-f5df8a966856
# TEAMS_CHANNEL_ID=19:84263863fa194d22aebc9a87d97c5c21@thread.tacv2
#
# Fallback: legacy incoming webhook URL
# TEAMS_WEBHOOK_URL=
# Optional: set at build/deploy time for version stamp in cards
# APP_BUILD_TIMESTAMP=
