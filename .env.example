# ──────────────────────────────────────────────────────
#  NBA GBSV v6 — Environment Variable Reference
# ──────────────────────────────────────────────────────
#  Copy this file to .env and fill in your API keys.
#  Per-environment overrides go in:
#    .env.development   (local Docker dev)
#    .env.test           (unit tests / CI)
#    .env.production     (documentation only — secrets
#                         are injected by Azure Key Vault)
# ──────────────────────────────────────────────────────

# ── Required secrets (must be set in .env) ────────────
ODDS_API_KEY=
BASKETBALL_API_KEY=

# ── Database ──────────────────────────────────────────
# Dev Container:  postgresql+asyncpg://postgres:postgres@db:5432/nba_gbsv
# Local machine:  postgresql+asyncpg://postgres:postgres@localhost:5432/nba_gbsv
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nba_gbsv

# ── App ───────────────────────────────────────────────
# Valid values: development | test | production
APP_ENV=development
LOG_LEVEL=INFO

# ── Azure (production only) ──────────────────────────
AZURE_KEY_VAULT_URL=

# ── Teams delivery ────────────────────────────────────
# Preferred: Graph API posting (uses DefaultAzureCredential)
# TEAMS_TEAM_ID=6d55cb22-b8b0-43a4-8ec1-f5df8a966856
# TEAMS_CHANNEL_ID=19:84263863fa194d22aebc9a87d97c5c21@thread.tacv2
#
# Fallback: legacy incoming webhook URL
# TEAMS_WEBHOOK_URL=
# Optional: set at build/deploy time for version stamp in cards
# APP_BUILD_TIMESTAMP=
