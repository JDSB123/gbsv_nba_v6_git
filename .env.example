# ----------------------------------------------------------------
# NBA GBSV v6 - Environment Variable Reference
# ----------------------------------------------------------------
# Canonical source of truth for cloud runtime values is the azd
# environment (which maps to ACA app settings).
# Local .env/.env.azure are generated mirrors for host execution.
# ----------------------------------------------------------------
# The root .env is the local host-development profile.
# Reset it to local defaults with:
#   python scripts/sync_env.py --force
#
# To create an Azure-attached host profile in .env.azure, run:
#   python scripts/sync_env.py --from-azd --output .env.azure --force --create-azd-env-if-missing
#
# Windows wrapper examples:
#   powershell -ExecutionPolicy Bypass -File .\scripts\setup-env.ps1 -Force
#   powershell -ExecutionPolicy Bypass -File .\scripts\setup-env.ps1 -Force -FromAzd -EnvironmentName <env> -OutputPath .env.azure -CreateAzdEnvIfMissing
#
# setup-env.ps1 writes .env.profile so host processes can resolve the
# active profile consistently across terminals/processes.
# G_BSV_ENV_FILE remains an explicit per-process override when needed.
# The default workflow is the VS Code dev container.
# ----------------------------------------------------------------

# Required secrets
# Replace these placeholders with real keys for live API calls.
ODDS_API_KEY=dev-odds-placeholder
BASKETBALL_API_KEY=dev-basketball-placeholder

# Database
# Dev container overrides this to:
#   postgresql+asyncpg://postgres:postgres@db:5432/nba_gbsv
# Host-only local runs should keep localhost.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nba_gbsv
# Set DB_SSL=false for local Postgres; leave unset (defaults true) for Azure Postgres
DB_SSL=false

# App
# Root .env stays on local development defaults.
APP_ENV=development
LOG_LEVEL=INFO
API_KEY=
API_BASE_URL=
ONEDRIVE_EXPORT_ROOT=
EXPORT_ALLOW_LOCAL_DB=false

# Azure
AZURE_KEY_VAULT_URL=
APPLICATIONINSIGHTS_CONNECTION_STRING=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_URL=

# Teams delivery
# Preferred: Graph API posting (uses DefaultAzureCredential)
# TEAMS_TEAM_ID=6d55cb22-b8b0-43a4-8ec1-f5df8a966856
# TEAMS_CHANNEL_ID=19:84263863fa194d22aebc9a87d97c5c21@thread.tacv2
#
# Fallback: legacy incoming webhook URL
TEAMS_WEBHOOK_URL=
