{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "postgresLocation": {
      "value": "${AZURE_POSTGRES_LOCATION}"
    },
    "environment": {
      "value": "${AZURE_RUNTIME_ENVIRONMENT}"
    },
    "postgresPassword": {
      "value": "${POSTGRES_PASSWORD}"
    },
    "oddsApiKey": {
      "value": "${ODDS_API_KEY}"
    },
    "basketballApiKey": {
      "value": "${BASKETBALL_API_KEY}"
    },
    "teamsWebhookUrl": {
      "value": "${TEAMS_WEBHOOK_URL}"
    },
    "apiKey": {
      "value": "${API_KEY}"
    },
    "containerAppsEnvironmentResourceId": {
      "value": "${CONTAINER_APPS_ENVIRONMENT_RESOURCE_ID}"
    }
  }
}