{
  "version": "2.0.0",
  "options": {
    "shell": {
      "executable": "pwsh.exe",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-Command"
      ]
    }
  },
  "tasks": [
    {
      "label": "dev: bootstrap host",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/scripts/bootstrap-host.ps1",
        "-SkipVSCodeExtensions"
      ],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "revealProblems": "onProblem",
        "panel": "dedicated",
        "focus": false,
        "close": false
      },
      "problemMatcher": {
        "owner": "bootstrap-host",
        "source": "bootstrap-host",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^BOOTSTRAP_ERROR\\s+([^:]+):(\\d+):\\s*(.+)$",
          "file": 1,
          "line": 2,
          "message": 3
        }
      }
    },
    {
      "label": "env: sync local",
      "detail": "Rewrite .env from src/config.py (Settings). Run 'Sync-Env' in your terminal afterward to refresh open shells.",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/scripts/setup-env.ps1",
        "-Force"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "close": false
      },
      "problemMatcher": []
    },
    {
      "label": "env: sync azure",
      "detail": "Rewrite .env from the active azd environment. Run 'Sync-Env -Azure' in your terminal afterward to refresh open shells.",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/scripts/setup-env.ps1",
        "-Force",
        "-FromAzd",
        "-CreateAzdEnvIfMissing"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "close": false
      },
      "problemMatcher": []
    },
    {
      "label": "app: serve",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "src",
        "serve"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "app: work",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "src",
        "work"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "model: retrain",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "src",
        "retrain"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "model: train",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "src",
        "train"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "model: predict",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "src",
        "predict"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "ops: audit",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "src",
        "audit"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "db: migrate",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "src",
        "migrate"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "ops: post-deploy smoke",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/scripts/post-deploy-smoke.ps1"
      ],
      "dependsOn": "env: sync azure",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "test",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pytest",
        "tests",
        "-v"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    }
  ]
}

