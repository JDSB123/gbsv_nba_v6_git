{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "env: bootstrap",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/scripts/setup-env.ps1"
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "db: migrate",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "src",
        "migrate"
      ],
      "problemMatcher": []
    },
    {
      "label": "test",
      "type": "shell",
      "command": "pytest",
      "args": [
        "tests",
        "-v"
      ],
      "problemMatcher": []
    }
  ]
}
