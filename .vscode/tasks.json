{
  "version": "2.0.0",
  "options": {
    "shell": {
      "executable": "pwsh.exe",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-Command"
      ]
    }
  },
  "tasks": [
    {
      "label": "dev: bootstrap host",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/scripts/bootstrap-host.ps1",
        "-SkipVSCodeExtensions"
      ],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "focus": false,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "env: bootstrap",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/scripts/setup-env.ps1"
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "env: reset local",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/scripts/setup-env.ps1",
        "-Force",
        "-OutputPath", ".env"
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "env: sync azure",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/scripts/setup-env.ps1",
        "-Force",
        "-FromAzd",
        "-OutputPath", ".env.azure",
        "-CreateAzdEnvIfMissing"
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "app: serve",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "src",
        "serve"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "app: work",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "src",
        "work"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "model: retrain",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "src",
        "retrain"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "model: train",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "src",
        "train"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "model: predict",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "src",
        "predict"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "ops: audit",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "src",
        "audit"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "db: migrate",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "src",
        "migrate"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "ops: post-deploy smoke",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/scripts/post-deploy-smoke.ps1"
      ],
      "dependsOn": "env: sync azure",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "test",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pytest",
        "tests",
        "-v"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    }
  ]
}

