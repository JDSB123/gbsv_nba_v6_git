{
  "version": "2.0.0",
  "options": {
    "shell": {
      "executable": "pwsh.exe",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-Command"
      ]
    }
  },
  "tasks": [
    {
      "label": "dev: bootstrap host",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/scripts/bootstrap-host.ps1",
        "-SkipVSCodeExtensions"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "env: bootstrap",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/scripts/setup-env.ps1"
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "env: reset local",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/scripts/setup-env.ps1",
        "-Force",
        "-OutputPath", ".env"
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "env: sync azure",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/scripts/setup-env.ps1",
        "-Force",
        "-FromAzd",
        "-OutputPath", ".env.azure",
        "-CreateAzdEnvIfMissing"
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "app: serve",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "src",
        "serve"
      ],
      "options": {
        "env": {
          "G_BSV_ENV_FILE": "${workspaceFolder}\\.env"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
