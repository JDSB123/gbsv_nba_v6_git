{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
  "python.envFile": "${workspaceFolder}/.env",
  "python.createEnvironment.trigger": "off",
  "python.createEnvironment.contentButton": "hide",
  "python.terminal.activateEnvironment": true,
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.terminal.useEnvFile": true,

  "terminal.integrated.defaultProfile.windows": "PowerShell (venv)",
  "terminal.integrated.profiles.windows": {
    "PowerShell (venv)": {
      "source": "PowerShell",
      "args": ["-NoExit", "-Command", ". '${workspaceFolder}/scripts/init-terminal.ps1'"]
    },
    "PowerShell": {
      "source": "PowerShell"
    }
  },

  "ruff.importStrategy": "useBundled",
  "ruff.nativeServer": "on",
  "ruff.configuration": "${workspaceFolder}/pyproject.toml",
  "ruff.configurationPreference": "filesystemFirst",

  // Disable redundant linters/formatters — this project uses ruff
  "autopep8.enabled": false,
  "black-formatter.enabled": false,
  "flake8.enabled": false,
  "isort.enabled": false,
  "mypy-type-checker.enabled": false,

  // Prevent external VS Code windows during bootstrap / normal use
  "window.openFoldersInNewWindow": "off",
  "window.openFilesInNewWindow": "off",
  "window.restoreWindows": "one",
  "extensions.autoUpdate": false,
  "extensions.autoCheckUpdates": false,
  "task.allowAutomaticTasks": "on",
  "dev.containers.reopenInContainer": "never",
  "remote.autoForwardPorts": false,

  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },

  "cSpell.words": [
    "aca",
    "alembic",
    "applicationinsights",
    "asyncio",
    "asyncpg",
    "azd",
    "bicep",
    "brier",
    "charliermarsh",
    "codeactions",
    "cors",
    "cspell",
    "datacls",
    "devcontainer",
    "dotenv",
    "entrypoint",
    "entrypoints",
    "fastapi",
    "gbsv",
    "gitignored",
    "graphviz",
    "h2h",
    "httpx",
    "keyvault",
    "kwargs",
    "levelname",
    "liveness",
    "lineitem",
    "lookback",
    "mypy",
    "nba",
    "noqa",
    "odds",
    "onedrive",
    "onprem",
    "optuna",
    "passlib",
    "pgadmin",
    "pinnacle",
    "postgres",
    "postgresql",
    "preprocess",
    "prestart",
    "pyproject",
    "pytest",
    "pydantic",
    "pwsh",
    "ruff",
    "runtimes",
    "scikit",
    "seaborn",
    "sklearn",
    "sqlalchemy",
    "structlog",
    "tacv2",
    "teamsclient",
    "uvicorn",
    "venv",
    "workbench",
    "xgboost"
  ]
}